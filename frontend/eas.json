{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local",
    "requireCommit": false,
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "base": {
      "android": {
        "image": "latest"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "production",
        "NODE_OPTIONS": "--max-old-space-size=8192",
        "EXPO_NO_TELEMETRY": "1",
        "EAS_NO_VCS": "1",
        "EAS_SKIP_AUTO_FINGERPRINT": "1",
        "GRADLE_OPTS": "-Xmx6g -Xms2g -XX:MaxMetaspaceSize=1024m -Dorg.gradle.daemon=false -Dorg.gradle.parallel=false -Dorg.gradle.configureondemand=false"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "env": {
        "EXPO_PUBLIC_APP_ENV": "development"
      },
      "ios": { "simulator": true }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease --stacktrace --no-daemon"
      }
    },
    "preview-safe": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease --stacktrace --no-daemon -PreactNativeArchitectures=arm64-v8a"
      },
      "env": {
        "EXPO_NO_PROGUARD": "1",
        "EXPO_NO_R8": "1"
      }
    },
    "preview-debug": {
      "extends": "base",
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease --stacktrace --info --no-daemon"
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease --stacktrace --no-daemon"
      }
    },
    "production-safe": {
      "extends": "base",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "gradleCommand": ":app:bundleRelease --stacktrace --no-daemon"
      },
      "env": {
        "EXPO_NO_PROGUARD": "1"
      }
    }
  },
  "submit": {
    "internal": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": false
      }
    },
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production",
        "releaseStatus": "completed",
        "changesNotSentForReview": false
      }
    }
  }
}
