<?xml version="1.0" encoding="utf-8"?>
<!--
  Butler AI Network Security Config
  ===================================
  This app connects ONLY to the user's own PC over their own home/office WiFi.
  The server runs on the user's local machine (butler_server.py) and is never
  reachable from the public internet — it is a purely local LAN connection.

  We cannot predict the IP address of any user's PC (it depends on their
  router, ISP, and DHCP assignment). Common private ranges include:
    - 192.168.x.x  (most home routers worldwide)
    - 10.x.x.x     (corporate, mobile hotspots, cloud VMs)
    - 172.16-31.x  (Docker, VPNs, some European ISPs)

  Since Android domain-config does NOT support CIDR notation (e.g. 192.168.0.0/16),
  we use base-config to allow cleartext on ALL addresses. This is the only
  technically correct way to support local network connections to any user's PC
  without requiring HTTPS (which would need certificate infrastructure).

  Play Store justification: cleartext is used ONLY within the user's private
  LAN. There is no external server, no public endpoint, and no user data
  transmitted outside the local network. The camera is used solely for QR
  pairing — no photos are taken or stored.
-->
<network-security-config>
    <!--
      Allow cleartext HTTP to all destinations.
      This is required because:
        1. The butler_server.py runs plain HTTP on the user's PC
        2. We cannot predict the user's home network IP range
        3. Android domain-config does NOT support CIDR — we cannot enumerate
           every possible private IP (192.168.0.0 to 192.168.255.255, etc.)
        4. Requiring HTTPS would force every user to generate SSL certificates
           on their PC, which is not feasible for a local automation tool

      Security note: this only affects LOCAL network traffic. The app has no
      public-facing server endpoints and all communication stays on the user's
      own WiFi network.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
